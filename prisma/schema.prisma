generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// 1. IDENTITY & ACCESS
// ─────────────────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  firstName   String    @db.VarChar(191)
  lastName    String    @db.VarChar(191)
  email       String    @unique @db.VarChar(191)
  passwordHash String?  @db.VarChar(255)
  emailVerifiedAt DateTime?
  phone       String?   @db.VarChar(50)
  branchId    String?   @db.Uuid
  accountType String    @db.VarChar(100)
  status      String    @db.VarChar(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relationships
  branch                 Branch?                 @relation("UserBranch", fields: [branchId], references: [id])
  userRoles              UserRole[]
  sessions               Session[]
  auditLogs              AuditLog[]              @relation("AuditLogActor")
  notifications          Notification[]          @relation("NotificationSender")
  notificationRecipients NotificationRecipient[]

  // Academic
  classesTeaching       Class[]                @relation("ClassTeacher")
  enrollments           Enrollment[]           @relation("EnrollmentStudent")
  assignmentSubmissions AssignmentSubmission[] @relation("SubmissionStudent")
  attendanceDetails     AttendanceDetail[]
  studentGrades         StudentGrade[]
  resourceDownloads     ResourceDownloadLog[]
  activityLogs          ActivityLog[]
  examAttempts          ExamAttempt[]

  // CRM
  leadsOwned    Lead[]
  consultations Consultation[]

  // Family
  asStudent  GuardianLink[] @relation("GuardianLinkStudent")
  asGuardian GuardianLink[] @relation("GuardianLinkGuardian")

  // Payroll
  salarySetting      SalarySetting?
  sessionPays        SessionPay[]
  payrollAdjustments PayrollAdjustment[]
  payrollsRunBy      PayrollRun[]

  @@map("users")
  @@index([createdAt])
  @@index([branchId])
  @@index([status])
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(191)
  description     String?          @db.Text
  status          String           @db.VarChar(100)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique @db.VarChar(191)
  category        String           @db.VarChar(191)
  action          String           @db.VarChar(191)
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String    @db.Uuid
  roleId     String    @db.Uuid
  assignedAt DateTime  @default(now())
  revokedAt  DateTime?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  deviceName String?  @db.VarChar(191)
  ipAddress  String?  @db.VarChar(100)
  status     String   @db.VarChar(100)
  risk       String?  @db.VarChar(100)
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@index([userId, createdAt])
  @@index([userId, status, expiresAt])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  module     String   @db.VarChar(191)
  action     String   @db.VarChar(191)
  targetId   String?  @db.Uuid
  targetType String?  @db.VarChar(191)
  before     Json?
  after      Json?
  timestamp  DateTime @default(now())
  actor      User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
  @@index([module, timestamp])
  @@index([actorId, timestamp])
  @@index([targetId, targetType, timestamp])
  @@index([timestamp])
}

// ─────────────────────────────────────────
// 2. ORGANIZATION
// ─────────────────────────────────────────

model Branch {
  id             String  @id @default(uuid()) @db.Uuid
  name           String  @db.VarChar(191)
  location       String? @db.Text
  status         String  @db.VarChar(100)
  parentBranchId String? @db.Uuid
  timezone       String? @db.VarChar(100)
  currency       String? @db.VarChar(10)

  // Relationships
  parentBranch       Branch?             @relation("BranchParent", fields: [parentBranchId], references: [id])
  childBranches      Branch[]            @relation("BranchParent")
  users              User[]              @relation("UserBranch")
  classes            Class[]
  leads              Lead[]
  salarySetting      SalarySetting[]
  payrollRuns        PayrollRun[]
  sessionPays        SessionPay[]
  payrollAdjustments PayrollAdjustment[]

  @@map("branches")
  @@index([name])
}

model Course {
  id            String  @id @default(uuid()) @db.Uuid
  name          String  @db.VarChar(191)
  level         String  @db.VarChar(100)
  description   String? @db.Text
  status        String  @db.VarChar(100)
  durationWeeks Int

  // Relationships
  classes             Class[]
  coursePrerequisites CoursePrerequisite[] @relation("CoursePrerequisites")
  isPrerequisiteOf    CoursePrerequisite[] @relation("IsPrerequisiteOf")

  @@map("courses")
  @@index([name])
}

model CoursePrerequisite {
  id             String @id @default(uuid()) @db.Uuid
  courseId       String @db.Uuid
  prerequisiteId String @db.Uuid
  course         Course @relation("CoursePrerequisites", fields: [courseId], references: [id], onDelete: Cascade)
  prerequisite   Course @relation("IsPrerequisiteOf", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@map("course_prerequisites")
}

// ─────────────────────────────────────────
// 3. ACADEMIC
// ─────────────────────────────────────────

model Class {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(191)
  courseId  String   @db.Uuid
  teacherId String?  @db.Uuid
  branchId  String   @db.Uuid
  status    String   @db.VarChar(100)
  capacity  Int
  startDate DateTime @db.Date
  endDate   DateTime @db.Date

  // Relationships
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Restrict)
  teacher           User?              @relation("ClassTeacher", fields: [teacherId], references: [id], onDelete: SetNull)
  branch            Branch             @relation(fields: [branchId], references: [id], onDelete: Restrict)
  enrollments       Enrollment[]
  assignments       Assignment[]
  resources         Resource[]
  attendanceRecords AttendanceRecord[]
  gradeComponents   GradeComponent[]
  activityLogs      ActivityLog[]
  classExams        ClassExam[]

  @@map("classes")
  @@index([branchId, startDate])
  @@index([teacherId, startDate])
  @@index([courseId, startDate])
}

model Enrollment {
  id         String   @id @default(uuid()) @db.Uuid
  classId    String   @db.Uuid
  studentId  String   @db.Uuid
  status     String   @db.VarChar(100)
  enrolledAt DateTime @default(now())

  // Relationships
  class   Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  student User  @relation("EnrollmentStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("enrollments")
  @@index([studentId, enrolledAt])
  @@index([classId, enrolledAt])
}

model Assignment {
  id          String   @id @default(uuid()) @db.Uuid
  classId     String   @db.Uuid
  title       String   @db.VarChar(191)
  description String?  @db.Text
  dueDate     DateTime @db.Date
  maxScore    Float

  // Relationships
  class       Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@map("assignments")
}

model AssignmentSubmission {
  id           String   @id @default(uuid()) @db.Uuid
  assignmentId String   @db.Uuid
  studentId    String   @db.Uuid
  submittedAt  DateTime @default(now())
  fileUrl      String?  @db.Text
  score        Float?
  feedback     String?  @db.Text
  status       String   @db.VarChar(100)

  // Relationships
  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation("SubmissionStudent", fields: [studentId], references: [id], onDelete: Cascade)

  @@map("assignment_submissions")
}

model AttendanceRecord {
  id           String   @id @default(uuid()) @db.Uuid
  classId      String   @db.Uuid
  date         DateTime @db.Date
  sessionLabel String?  @db.VarChar(191)
  presentCount Int
  absentCount  Int
  lateCount    Int

  // Relationships
  class   Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  details AttendanceDetail[]

  @@map("attendance_records")
}

model AttendanceDetail {
  id                 String  @id @default(uuid()) @db.Uuid
  attendanceRecordId String  @db.Uuid
  studentId          String  @db.Uuid
  status             String  @db.VarChar(100)
  note               String? @db.Text

  // Relationships
  attendanceRecord AttendanceRecord @relation(fields: [attendanceRecordId], references: [id], onDelete: Cascade)
  student          User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("attendance_details")
}

model GradeComponent {
  id      String @id @default(uuid()) @db.Uuid
  classId String @db.Uuid
  name    String @db.VarChar(191)
  weight  Float
  type    String @db.VarChar(100)

  // Relationships
  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentGrades StudentGrade[]

  @@map("grade_components")
}

model StudentGrade {
  id          String   @id @default(uuid()) @db.Uuid
  componentId String   @db.Uuid
  studentId   String   @db.Uuid
  score       Float
  gradedBy    String?  @db.Uuid
  gradedAt    DateTime @default(now())

  // Relationships
  component GradeComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)
  student   User           @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_grades")
}

model Resource {
  id      String @id @default(uuid()) @db.Uuid
  classId String @db.Uuid
  title   String @db.VarChar(191)
  type    String @db.VarChar(100)
  url     String @db.Text

  // Relationships
  class        Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)
  downloadLogs ResourceDownloadLog[]

  @@map("resources")
}

model ResourceDownloadLog {
  id           String   @id @default(uuid()) @db.Uuid
  resourceId   String   @db.Uuid
  userId       String   @db.Uuid
  downloadedAt DateTime @default(now())

  // Relationships
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  downloader User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resource_download_logs")
}

model ActivityLog {
  id         String   @id @default(uuid()) @db.Uuid
  classId    String   @db.Uuid
  actorId    String   @db.Uuid
  capability String   @db.VarChar(191)
  timestamp  DateTime @default(now())

  // Relationships
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  actor User  @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

// ─────────────────────────────────────────
// 4. CRM / SALES
// ─────────────────────────────────────────

model Lead {
  id        String   @id @default(uuid()) @db.Uuid
  branchId  String?  @db.Uuid
  ownerId   String?  @db.Uuid
  name      String   @db.VarChar(191)
  phone     String   @db.VarChar(100)
  email     String?  @db.VarChar(191)
  source    String?  @db.VarChar(191)
  status    String   @db.VarChar(100)
  score     Int      @default(0)
  createdAt DateTime @default(now())

  // Relationships
  branch        Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  owner         User?               @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  statusHistory LeadStatusHistory[]
  consultations Consultation[]

  @@map("leads")
  @@index([ownerId, createdAt])
  @@index([status, createdAt])
  @@index([branchId, createdAt])
  @@index([phone])
}

model LeadStatusHistory {
  id         String   @id @default(uuid()) @db.Uuid
  leadId     String   @db.Uuid
  fromStatus String   @db.VarChar(100)
  toStatus   String   @db.VarChar(100)
  changedBy  String?  @db.Uuid
  changedAt  DateTime @default(now())
  note       String?  @db.Text

  // Relationships
  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_status_histories")
  @@index([leadId, changedAt])
}

model Consultation {
  id           String    @id @default(uuid()) @db.Uuid
  leadId       String    @db.Uuid
  staffId      String?   @db.Uuid
  date         DateTime  @db.Date
  outcome      String?   @db.VarChar(191)
  followUpNote String?   @db.Text
  followUpDate DateTime? @db.Date
  status       String    @db.VarChar(100)

  // Relationships
  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  staff User? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@map("consultations")
  @@index([leadId, date])
  @@index([staffId, date])
}

// ─────────────────────────────────────────
// 5. FAMILY
// ─────────────────────────────────────────

model GuardianLink {
  id                String    @id @default(uuid()) @db.Uuid
  studentId         String    @db.Uuid
  guardianId        String    @db.Uuid
  relationshipType  String    @db.VarChar(191)
  status            String    @db.VarChar(100)
  isPrimary         Boolean   @default(false)
  verifiedAt        DateTime?
  canViewGrades     Boolean   @default(false)
  canViewAttendance Boolean   @default(false)
  canViewFinance    Boolean   @default(false)

  // Relationships
  student  User @relation("GuardianLinkStudent", fields: [studentId], references: [id], onDelete: Cascade)
  guardian User @relation("GuardianLinkGuardian", fields: [guardianId], references: [id], onDelete: Cascade)

  @@map("guardian_links")
}

// ─────────────────────────────────────────
// 6. EXAM ENGINE
// ─────────────────────────────────────────

model ClassExam {
  id      String @id @default(uuid()) @db.Uuid
  classId String @db.Uuid
  examId  String @db.Uuid

  // Relationships
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)
  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("class_exams")
}

model Exam {
  id                   String  @id @default(uuid()) @db.Uuid
  createdById          String? @db.Uuid
  category             String? @db.VarChar(191)
  title                String  @db.VarChar(191)
  status               String  @db.VarChar(100)
  totalDurationMinutes Int
  allowReview          Boolean @default(false)
  allowSkip            Boolean @default(false)
  randomizeQuestions   Boolean @default(false)
  randomizeOptions     Boolean @default(false)
  showScore            Boolean @default(false)
  showAnswers          Boolean @default(false)
  passwordProtected    Boolean @default(false)
  requireProctoring    Boolean @default(false)

  // Relationships
  examSections  ExamSection[]
  examSchedules ExamSchedule[]
  classExams    ClassExam[]
  examAttempts  ExamAttempt[]

  @@map("exams")
}

model ExamSchedule {
  id          String   @id @default(uuid()) @db.Uuid
  examId      String   @db.Uuid
  startAt     DateTime
  endAt       DateTime
  maxAttempts Int
  password    String?  @db.VarChar(191)

  // Relationships
  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_schedules")
}

model ExamSection {
  id              String @id @default(uuid()) @db.Uuid
  examId          String @db.Uuid
  title           String @db.VarChar(191)
  durationMinutes Int
  order           Int

  // Relationships
  exam          Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  examQuestions ExamQuestion[]

  @@map("exam_sections")
}

model ExamQuestion {
  id           String  @id @default(uuid()) @db.Uuid
  sectionId    String  @db.Uuid
  type         String  @db.VarChar(100)
  instructions String? @db.Text
  points       Float
  order        Int

  // Relationships
  section            ExamSection         @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  questionOptions    QuestionOption[]
  questionBlanks     QuestionBlank[]
  questionMatchItems QuestionMatchItem[]
  questionRubric     QuestionRubric?
  attemptAnswers     AttemptAnswer[]

  @@map("exam_questions")
}

model QuestionOption {
  id         String  @id @default(uuid()) @db.Uuid
  questionId String  @db.Uuid
  text       String  @db.Text
  isCorrect  Boolean @default(false)
  order      Int

  // Relationships
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_options")
}

model QuestionBlank {
  id         String @id @default(uuid()) @db.Uuid
  questionId String @db.Uuid
  answer     String @db.Text
  blankIndex Int

  // Relationships
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_blanks")
}

model QuestionMatchItem {
  id          String  @id @default(uuid()) @db.Uuid
  questionId  String  @db.Uuid
  text        String  @db.Text
  itemType    String  @db.VarChar(100)
  matchPairId String? @db.Uuid

  // Relationships
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_match_items")
}

model QuestionRubric {
  id          String @id @default(uuid()) @db.Uuid
  questionId  String @unique @db.Uuid
  rubricGuide String @db.Text
  maxScore    Float

  // Relationships
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("question_rubrics")
}

model ExamAttempt {
  id            String    @id @default(uuid()) @db.Uuid
  examId        String    @db.Uuid
  studentId     String    @db.Uuid
  status        String    @db.VarChar(100)
  score         Float?
  attemptNumber Int
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?

  // Relationships
  exam           Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student        User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attemptAnswers AttemptAnswer[]

  @@map("exam_attempts")
}

model AttemptAnswer {
  id           String   @id @default(uuid()) @db.Uuid
  attemptId    String   @db.Uuid
  questionId   String   @db.Uuid
  answerData   Json?
  isCorrect    Boolean?
  scoreAwarded Float?

  // Relationships
  attempt  ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("attempt_answers")
}

// ─────────────────────────────────────────
// 7. PAYROLL
// ─────────────────────────────────────────

model SalarySetting {
  id            String    @id @default(uuid()) @db.Uuid
  teacherId     String    @unique @db.Uuid
  branchId      String    @db.Uuid
  baseRate      Decimal   @db.Decimal(12, 2)
  sessionRate   Decimal   @db.Decimal(12, 2)
  overtimeRate  Decimal   @db.Decimal(12, 2)
  status        String    @db.VarChar(100)
  effectiveFrom DateTime  @db.Date
  effectiveTo   DateTime? @db.Date

  // Relationships
  teacher User   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  branch  Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("salary_settings")
}

model SessionPay {
  id           String   @id @default(uuid()) @db.Uuid
  teacherId    String   @db.Uuid
  branchId     String   @db.Uuid
  classId      String?  @db.Uuid
  payrollRunId String?  @db.Uuid
  sessionDate  DateTime @db.Date
  sessionCount Int
  amount       Decimal  @db.Decimal(12, 2)
  bonus        Decimal  @default(0) @db.Decimal(12, 2)

  // Relationships
  teacher    User        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@map("session_pays")
  @@index([teacherId, sessionDate])
  @@index([branchId, sessionDate])
  @@index([payrollRunId])
}

model PayrollAdjustment {
  id           String  @id @default(uuid()) @db.Uuid
  teacherId    String  @db.Uuid
  branchId     String  @db.Uuid
  payrollRunId String? @db.Uuid
  periodYear   Int
  periodMonth  Int
  type         String  @db.VarChar(100)
  amount       Decimal @db.Decimal(12, 2)
  status       String  @db.VarChar(100)
  note         String? @db.Text

  // Relationships
  teacher    User        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  branch     Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun? @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)

  @@map("payroll_adjustments")
  @@index([teacherId, periodYear, periodMonth])
  @@index([branchId, periodYear, periodMonth])
  @@index([payrollRunId])
}

model PayrollRun {
  id            String   @id @default(uuid()) @db.Uuid
  branchId      String   @db.Uuid
  periodYear    Int
  periodMonth   Int
  totalTeachers Int
  grossAmount   Decimal  @db.Decimal(12, 2)
  netAmount     Decimal  @db.Decimal(12, 2)
  status        String   @db.VarChar(100)
  runAt         DateTime @default(now())
  runBy         String?  @db.Uuid

  // Relationships
  branch             Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  runByUser          User?               @relation(fields: [runBy], references: [id], onDelete: SetNull)
  sessionPays        SessionPay[]
  payrollAdjustments PayrollAdjustment[]

  @@map("payroll_runs")
  @@index([branchId, runAt])
  @@index([periodYear, periodMonth])
  @@index([runBy])
}

// ─────────────────────────────────────────
// 8. NOTIFICATION
// ─────────────────────────────────────────

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  senderId    String?   @db.Uuid
  title       String    @db.VarChar(191)
  body        String    @db.Text
  type        String    @db.VarChar(100)
  status      String    @db.VarChar(100)
  scheduledAt DateTime?
  sentAt      DateTime?

  // Relationships
  sender     User?                   @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)
  recipients NotificationRecipient[]

  @@map("notifications")
}

model NotificationRecipient {
  id             String    @id @default(uuid()) @db.Uuid
  notificationId String    @db.Uuid
  userId         String    @db.Uuid
  isRead         Boolean   @default(false)
  readAt         DateTime?

  // Relationships
  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_recipients")
  @@index([userId, isRead])
  @@index([notificationId])
}
