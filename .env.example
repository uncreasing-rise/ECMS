# App
PORT=3000
FRONTEND_URL=http://localhost:3001

# Database (required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecms

# Auth (required)
JWT_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret

# Redis (required): choose ONE option below
# Option A: Redis TCP
REDIS_URL=redis://localhost:6379

# Option B: Upstash REST
# UPSTASH_REDIS_REST_URL=https://your-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Mail (optional)
RESEND_API_KEY=
MAIL_FROM=ECMS <noreply@example.com>

# Firebase Push (optional)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
